# ─── Copy to .env and fill in real values ───────────────────────────────────

# Public base URL of the running app (no trailing slash).
BASE_URL=http://localhost:4173

PORT=4173
NODE_ENV=development

# ─── LinkedIn OAuth (OpenID Connect) ────────────────────────────────────────
# Create an app at https://www.linkedin.com/developers/apps
# Add the "Sign In with LinkedIn using OpenID Connect" product.
# Register these redirect URLs in the Auth tab:
#   http://localhost:4173/auth/linkedin/callback
#   https://YOUR-APP.onrender.com/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── Secrets ────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

SESSION_TTL_DAYS=30
